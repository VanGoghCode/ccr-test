# CCR local development environment example
# Copy this file to .env and replace placeholder values.

# Provider mode for the local sandbox backend
CCR_PROVIDER=asu

# Local server settings
PORT=3030
PROMPT_ROOT=prompts

# ASU AIML provider settings
ASU_API_KEY=your-asu-api-key
ASU_MODEL=gpt5_2
ASU_BASE_URL=https://api-main.aiml.asu.edu/queryV2
ASU_MODEL_PROVIDER=provider-id
ASU_TEMPERATURE=0.2
ASU_TIMEOUT_MS=120000

# Optional: estimated token pricing used for run metrics in reports
CCR_EST_INPUT_COST_PER_1M_USD=5
CCR_EST_OUTPUT_COST_PER_1M_USD=15
